<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Remove="memm\**" />
  </ItemGroup>

  <ItemGroup>
    <None Include="CODEX_JP.md" />
    <None Include="docs\fop.md" />
    <None Include="compiler\README.md" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="files\ReadFile.fs" />
    <Compile Include="compiler\FlatAST.fs" />
    <Compile Include="compiler\ASTInserter.fs" />
    <Compile Include="compiler\TypeInference.fs" />
    <Compile Include="compiler\SimpleScope.fs" />
    <Compile Include="compiler\Parser.Module.fs" />
    <Compile Include="compiler\Parser.fs" />
	<Compile Include="arc\ARC.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FParsec" Version="1.1.1" />
  </ItemGroup>

</Project>
