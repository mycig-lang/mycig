    <tags>F# fsharp formatting beautifier indentation indenter</tags>
    <packageTypes>
      <packageType name="DotnetTool" />
    </packageTypes>
    <repository type="git" url="https://github.com/nojaf/fantomas.git" commit="cbaa31cc6977666ab1103b1ee49aff31b85e39d8" />
  </metadata>
</package>